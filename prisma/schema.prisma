// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "mongodb"
  url=env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

model Logement {
  id String  @id@default(auto()) @map("_id") @db.ObjectId
  titre String
  ville String
  prix Int
  id_proprio String @db.ObjectId

  proprietaire Utilisateur @relation("ProprietaireLogements", fields: [id_proprio], references: [id])

  reservations Reservation[]
}

model Utilisateur {
  id String  @id@default(auto()) @map("_id") @db.ObjectId
  nom String
  email String
  role String
  DateNaissance DateTime

  logements Logement[] @relation("ProprietaireLogements")
  reservationsClient Reservation[] @relation("ClientReservations")
}

model Reservation {
  id String  @id@default(auto()) @map("_id") @db.ObjectId
  DateArrive DateTime
  DateDepart DateTime
  id_client String @db.ObjectId
  id_logement String @db.ObjectId

  client Utilisateur @relation("ClientReservations", fields: [id_client], references: [id])

  logement Logement @relation(fields: [id_logement], references: [id])
}
